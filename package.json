{
  "name": "smart-dispatch-rules",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,rs}\"",
    "test": "turbo run test",
    "test:e2e:ui": "playwright test",
    "test:e2e:ui:headed": "playwright test --headed",
    "test:e2e:ui:debug": "playwright test --debug",
    "test:e2e:ui:report": "playwright show-report",
    "playwright:install": "playwright install",
    "playwright:install:browsers": "playwright install chromium firefox webkit",
    "db:migrate": "cd apps/api && cargo run --bin migration",
    "db:reset": "cd apps/api && cargo run --bin migration -- reset",
    "backend:dev": "cd apps/api && cargo run",
    "backend:build": "cd apps/api && cargo build --release",
    "frontend:dev": "cd apps/web && npm run dev",
    "frontend:build": "cd apps/web && npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "prettier": "^3.2.0",
    "turbo": "^1.12.0"
  },
  "engines": {
    "node": ">=18"
  }
}
